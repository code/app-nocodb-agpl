      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "lodash@<4.18.0": ">=4.18.0",
      "lodash-es@<4.18.0": ">=4.18.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=4.0.0 <4.2.5": ">=4.2.5",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
